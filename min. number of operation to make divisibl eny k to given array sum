class Solution {
    public int minOperations(int[] nums, int k) {
         int sum =0;
         int n = nums.length;
         int r =0;
         int maxIndex =0;
         

         for(int i=1;i<n;i++){
            if(nums[i]>nums[maxIndex]){
              maxIndex=i;
            }
         }

         for(int i =0;i<n;i++){
            sum += nums[i];
         }

         if(sum%k==0){
            return 0;
         }
         
         if (sum%k != 0){
            r = sum%k;

            for(int i=0;i<r;i++){

                nums[maxIndex]-=1;
            }
            return r;

         }

            return 0;
    }
}
