class Solution {
    public boolean checkPalindromeFormation(String a, String b) {

        int l1 =a.length();
        int l2 =b.length();

        if(l1==l2 && l1==1){ return true;}

        else if(l1==l2){

            if(l1%2 == 0) { return true;}

            else
            return false;
        }
        else 
        return false;
   
    }
}
